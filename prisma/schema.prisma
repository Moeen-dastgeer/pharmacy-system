// Pharmacy Management System - Complete Database Schema
// POS System + Stock Management + Returns + Rack System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== Categories =====
model Category {
  id          String     @id @default(cuid())
  name        String
  description String?
  medicines   Medicine[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ===== Medicines =====
model Medicine {
  id            String      @id @default(cuid())
  name          String
  genericName   String?
  description   String?
  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id])
  price         Float
  stock         Int         @default(0)
  minStock      Int         @default(10)
  batchNumber   String?
  expiryDate    DateTime?
  manufacturer  String?
  supplier      Supplier?   @relation(fields: [supplierId], references: [id])
  supplierId    String?
  barcode       String?     @unique
  unit          String      @default("pieces")
  rackLocation  String?     // Where medicine is stored
  isActive      Boolean     @default(true)
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  stockLogs     StockLog[]
  returns       ReturnItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([categoryId])
  @@index([supplierId])
  @@index([expiryDate])
  @@index([barcode])
  @@index([rackLocation])
}

// ===== Customers =====
model Customer {
  id        String     @id @default(cuid())
  name      String
  email     String?    @unique
  phone     String?
  address   String?
  taxId     String?
  sales     Sale[]
  returns   Return[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// ===== Suppliers =====
model Supplier {
  id        String     @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String?
  medicines Medicine[]
  purchases PurchaseOrder[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// ===== Sales =====
model Sale {
  id            String     @id @default(cuid())
  invoiceNumber String     @unique
  customerId    String?
  customer      Customer?  @relation(fields: [customerId], references: [id])
  subtotal      Float
  discount      Float      @default(0)
  tax           Float      @default(0)
  total         Float
  paymentMethod String     @default("cash")
  status        String     @default("completed") // completed, returned, partial_return
  notes         String?
  items         SaleItem[]
  returns       Return[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([customerId])
  @@index([invoiceNumber])
  @@index([createdAt])
}

// ===== Sale Items =====
model SaleItem {
  id         String   @id @default(cuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id])
  quantity   Int
  unitPrice  Float
  discount   Float    @default(0)
  total      Float
  returnQuantity Int @default(0)
  createdAt  DateTime @default(now())

  @@index([saleId])
  @@index([medicineId])
}

// ===== Returns =====
model Return {
  id            String     @id @default(cuid())
  returnNumber  String     @unique
  saleId        String
  sale          Sale       @relation(fields: [saleId], references: [id])
  customerId    String?
  customer      Customer?  @relation(fields: [customerId], references: [id])
  subtotal      Float
  refundAmount  Float
  reason        String?
  status        String     @default("approved") // pending, approved, rejected
  items         ReturnItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([saleId])
  @@index([customerId])
}

// ===== Return Items =====
model ReturnItem {
  id         String   @id @default(cuid())
  returnId   String
  return     Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id])
  quantity   Int
  unitPrice  Float
  total      Float
  createdAt  DateTime @default(now())

  @@index([returnId])
  @@index([medicineId])
}

// ===== Purchase Orders =====
model PurchaseOrder {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  supplierId    String?
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
  subtotal      Float
  discount      Float         @default(0)
  tax           Float         @default(0)
  total         Float
  status        String        @default("pending") // pending, received, cancelled
  receivedDate  DateTime?
  notes         String?
  items         PurchaseItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([supplierId])
  @@index([orderNumber])
}

// ===== Purchase Items =====
model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    PurchaseOrder @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  medicineId  String
  medicine    Medicine @relation(fields: [medicineId], references: [id])
  quantity    Int
  unitPrice   Float
  discount    Float    @default(0)
  total       Float
  createdAt   DateTime @default(now())

  @@index([purchaseId])
  @@index([medicineId])
}

// ===== Stock Logs =====
model StockLog {
  id          String   @id @default(cuid())
  medicineId  String
  medicine    Medicine @relation(fields: [medicineId], references: [id])
  type        String   // "purchase", "sale", "return", "adjustment", "transfer"
  quantity    Int      // positive for in, negative for out
  notes       String?
  reference   String?  // invoice number or order number
  createdAt   DateTime @default(now())

  @@index([medicineId])
  @@index([createdAt])
  @@index([type])
}

// ===== Stock Transfers =====
model StockTransfer {
  id          String   @id @default(cuid())
  transferNumber String @unique
  medicineId  String
  fromRack    String?
  toRack      String?
  quantity    Int
  reason      String?
  createdAt   DateTime @default(now())
}

// ===== Staff =====
model Staff {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  role      String   @default("staff") // admin, pharmacist, staff
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== Discounts =====
model Discount {
  id        String   @id @default(cuid())
  code      String   @unique
  type      String   // percentage, fixed
  value     Float
  minPurchase Float?
  maxDiscount Float?
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  usageCount Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== Report Settings =====
model ReportSettings {
  id           String   @id @default(cuid())
  pharmacyName String
  address      String?
  phone        String?
  email        String?
  taxRate      Float    @default(0)
  currency     String   @default("PKR")
  logo         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}